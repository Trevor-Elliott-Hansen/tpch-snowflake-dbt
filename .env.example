# =============================================================================
# .env.example  —  copy to .env and fill in your own credentials
# =============================================================================
# This file is committed; .env is git-ignored.
# Load with `source .env` (bash/zsh) or `direnv` / `dotenv` in your toolchain.
# =============================================================================

# --- Snowflake connection (required) -----------------------------------------
SNOWFLAKE_ACCOUNT=xy12345.us-east-1     # your Snowflake account locator
SNOWFLAKE_USER=your_user
SNOWFLAKE_DATABASE=ANALYTICS
SNOWFLAKE_WAREHOUSE=TRANSFORMING
SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_SCHEMA=DBT_DEV                # default schema for dev target

# --- Auth: choose ONE of the two methods below -------------------------------

# Option A: Password auth (used by `dev` target in profiles.yml.example)
SNOWFLAKE_PASSWORD=

# Option B: Key-pair auth (used by `prod` target in profiles.yml.example)
# SNOWFLAKE_PRIVATE_KEY_PATH=~/.ssh/snowflake_rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
